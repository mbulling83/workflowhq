# Neon Auth URL — get from Neon Console → Project → Auth → Configuration
NEXT_PUBLIC_NEON_AUTH_URL=https://ep-lively-grass-abagr2z4.neonauth.eu-west-2.aws.neon.tech/neondb/auth

# Neon Postgres connection string (use pooler URL)
DATABASE_URL=postgresql://neondb_owner:...@ep-lively-grass-abagr2z4-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

# AES-256-GCM encryption key — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string-here

# Secret for signing Neon Auth session cookies (min 32 chars) — generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=your-32-char-secret-here

# Comma-separated emails allowed to read the feedback inbox in Settings
FEEDBACK_ADMIN_EMAILS=you@example.com

# Optional: if set, feedback and bug logs also create GitHub issues in this repo (owner/repo)
GITHUB_ISSUES_REPO=your-org/your-repo
# Optional: GitHub token with "repo" scope for issue creation
GITHUB_ISSUES_TOKEN=ghp_your_token_here
